[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/BHAVANA-srm/HelloApp.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "dev"]
	vscode-merge-base = origin/main
[branch "feature/UC1"]
	vscode-merge-base = origin/main
[branch "feature/UC2-display-name"]
	vscode-merge-base = origin/main
